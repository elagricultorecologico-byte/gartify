generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  name        String?
  email       String       @unique
  password    String?
  phone          String?
  whatsappOptIn  Boolean      @default(false)
  role           String       @default("CUSTOMER")
  bookings    Booking[]
  reviews     Review[]
  garage      Garage?
  distributor Distributor?
  vehicles    Vehicle[]
  createdAt   DateTime     @default(now())
}

model Garage {
  id            String          @id @default(cuid())
  name          String
  description   String?
  address       String
  city          String
  province      String    @default("")
  postalCode    String
  phone         String
  email         String?
  lat           Float?
  lng           Float?
  logo          String?
  rating        Float           @default(0)
  reviewCount   Int             @default(0)
  plan                 String    @default("STARTER")  // STARTER | PRO | PREMIUM
  stripeCustomerId     String?                         // ID de cliente en Stripe
  stripeSubscriptionId String?                         // ID de suscripción activa en Stripe
  stripePriceId        String?                         // Price ID de Stripe activo
  planExpiresAt        DateTime?                       // Fecha de expiración / próxima renovación
  vehicleTypes         String    @default("[\"COCHE\"]") // JSON array: COCHE|MOTO|FURGONETA|AUTOCARAVANA|CAMPER|CAMION
  categories           String    @default("[]")           // JSON array de categorías del taller
  laborRate            Float?                          // Precio mano de obra €/hora
  anchorPrices         String?                         // JSON: {revisionBasica, preItv, aireAcondicionado}
  excludedBrands       String?                         // JSON array de marcas excluidas
  isVerified    Boolean         @default(false)
  isActive      Boolean         @default(true)
  courtesyCar   Boolean         @default(false)
  pickupService Boolean         @default(false)
  ownerId       String          @unique
  owner         User            @relation(fields: [ownerId], references: [id])
  services      GarageService[]
  bookings      Booking[]
  reviews       Review[]
  schedules      GarageSchedule[]
  invoices       AdminInvoice[]
  partOrders     PartOrder[]
  offers         GarageOffer[]
  serviceRecords ServiceRecord[]          // Sellos emitidos por este taller
  blockedSlots   BlockedSlot[]
  createdAt      DateTime        @default(now())
}

model GarageOffer {
  id        String   @id @default(cuid())
  garageId  String
  garage    Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)
  label     String           // Ej: "Cambio de aceite express"
  days      String           // JSON array de días: ["LUN","MAR"]
  startTime String           // "10:00"
  endTime   String           // "12:00"
  price     Float            // Precio de la oferta
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model GarageSchedule {
  id        String  @id @default(cuid())
  garageId  String
  garage    Garage  @relation(fields: [garageId], references: [id], onDelete: Cascade)
  dayOfWeek Int     // 0=Dom, 1=Lun, 2=Mar, 3=Mié, 4=Jue, 5=Vie, 6=Sáb
  isOpen         Boolean @default(true)
  openTime       String  @default("08:00")
  closeTime      String  @default("18:00")
  afternoonStart String? // null = jornada continua
  afternoonEnd   String?

  @@unique([garageId, dayOfWeek])
}

model GarageService {
  id           String    @id @default(cuid())
  garageId     String
  garage       Garage    @relation(fields: [garageId], references: [id], onDelete: Cascade)
  type         String
  name         String
  description  String?
  price        Float
  duration     Int
  isActive     Boolean   @default(true)
  vehicleTypes String    @default("[\"COCHE\",\"MOTO\",\"FURGONETA\",\"AUTOCARAVANA\",\"CAMPER\",\"CAMION\"]") // JSON array: tipos de vehículo que admite este servicio
  bookings     Booking[]
}

model Booking {
  id           String         @id @default(cuid())
  code         String         @unique @default("")
  source       String         @default("GARTIFY")  // GARTIFY | MANUAL
  userId       String?
  user         User?          @relation(fields: [userId], references: [id])
  garageId     String
  garage       Garage         @relation(fields: [garageId], references: [id])
  serviceId    String?
  service      GarageService? @relation(fields: [serviceId], references: [id])
  serviceLabel String?                              // Descripción libre para reservas manuales
  clientName   String?                              // Nombre cliente para reservas manuales
  clientPhone  String?                              // Teléfono cliente para reservas manuales
  date         DateTime
  status       String         @default("PENDING")
  vehicleType  String         @default("COCHE")
  vehiclePlate String?
  vehicleModel String?
  notes        String?
  totalPrice   Float          @default(0)
  vehicleId    String?
  vehicle      Vehicle?       @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  review         Review?
  serviceRecord  ServiceRecord?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model AdminInvoice {
  id        String    @id @default(cuid())
  garageId  String
  garage    Garage    @relation(fields: [garageId], references: [id])
  month     String    // "2026-03" (YYYY-MM)
  revenue   Float     // suma de COMPLETED bookings del mes
  feeRate   Float     @default(0.10) // 10 %
  feeAmount Float     // revenue * feeRate
  status    String    @default("PENDING") // PENDING | PAID
  paidAt    DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  @@unique([garageId, month])
}

// ─── Módulo Recambios ─────────────────────────────────────────────────────────

model Distributor {
  id        String            @id @default(cuid())
  name      String
  email     String            @unique
  phone     String?
  website   String?
  logoUrl   String?
  isActive  Boolean           @default(true)
  // Cuenta de usuario vinculada al distribuidor (opcional: puede existir sin cuenta)
  userId    String?           @unique
  user      User?             @relation(fields: [userId], references: [id])
  parts     DistributorPart[]
  orders    PartOrder[]
  createdAt DateTime          @default(now())
}

model Part {
  id               String            @id @default(cuid())
  referenciaOem    String            @unique
  ean              String?
  nombre           String
  marcaFabricante  String
  categoria        String
  subcategoria     String?
  marcaVehiculo    String?
  modeloVehiculo   String?
  anioDesde        Int?
  anioHasta        Int?
  pesoKg           Float?
  imagenUrl        String?
  distributorParts DistributorPart[]
}

model DistributorPart {
  id                  String          @id @default(cuid())
  distributorId       String
  distributor         Distributor     @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  partId              String
  part                Part            @relation(fields: [partId], references: [id], onDelete: Cascade)
  referenciaProveedor String
  precioCoste         Float
  precioPvp           Float?
  ivaPct              Int             @default(21)
  stock               Int             @default(0)
  unidad              String          @default("ud")
  plazoEntregaHoras   Int             @default(24)
  notas               String?
  orderLines          PartOrderLine[]
  updatedAt           DateTime        @updatedAt

  @@unique([distributorId, referenciaProveedor])
}

model PartOrder {
  id            String          @id @default(cuid())
  garageId      String
  garage        Garage          @relation(fields: [garageId], references: [id])
  distributorId String
  distributor   Distributor     @relation(fields: [distributorId], references: [id])
  lines         PartOrderLine[]
  status          String          @default("PENDING") // PENDING|CONFIRMED|SHIPPED|DELIVERED|CANCELLED
  statusUpdatedAt DateTime        @default(now())     // Momento de la última transición de estado
  totalAmount     Float
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model PartOrderLine {
  id                String          @id @default(cuid())
  orderId           String
  order             PartOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  distributorPartId String
  distributorPart   DistributorPart @relation(fields: [distributorPartId], references: [id])
  cantidad          Int
  precioUnitario    Float
}

// ─────────────────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  garageId  String
  garage    Garage   @relation(fields: [garageId], references: [id])
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}

// ─── Vehículos del Cliente ────────────────────────────────────────────────────

model Vehicle {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  alias          String?                   // Apodo personalizado, ej: "Mi Seat"
  plate          String                    // Matrícula, ej: 1234-ABC
  brand          String                    // Marca, ej: Toyota
  model          String                    // Modelo, ej: Corolla
  year           Int?                      // Año de fabricación
  color          String?                   // Color del vehículo, ej: Blanco
  fuel           String?                   // Gasolina | Diésel | Híbrido | Eléctrico | GLP
  mileage        Int?                      // Kilómetros actuales
  itvDate        DateTime?                 // Próxima ITV
  itvReminder    Boolean   @default(false) // Enviar recordatorio de ITV por email
  bookings       Booking[]
  serviceRecords ServiceRecord[]           // Historial de revisiones del vehículo
  createdAt      DateTime        @default(now())
}

// ─── Catálogo de Vehículos ────────────────────────────────────────────────────

model VehicleMake {
  id      Int            @id @default(autoincrement())
  name    String         @unique
  logoUrl String?
  models  VehicleModel[]
}

model VehicleModel {
  id       Int              @id @default(autoincrement())
  name     String
  makeId   Int
  make     VehicleMake      @relation(fields: [makeId], references: [id], onDelete: Cascade)
  versions VehicleVersion[]
}

model VehicleVersion {
  id      Int          @id @default(autoincrement())
  name    String
  modelId Int
  model   VehicleModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
}

// ─── Libro de Revisiones ──────────────────────────────────────────────────────

model ServiceRecord {
  id           String    @id @default(cuid())
  // Vínculo al vehículo registrado (opcional — puede no estar registrado)
  vehicleId    String?
  vehicle      Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  // Vínculo a la reserva completada (único: una reserva → un sello)
  bookingId    String    @unique
  booking      Booking   @relation(fields: [bookingId], references: [id])
  // Taller que emite el sello
  garageId     String
  garage       Garage    @relation(fields: [garageId], references: [id])
  // Datos del vehículo en el momento del servicio (desnormalizados para historial)
  vehiclePlate String?
  vehicleModel String?
  // Contenido del sello
  date         DateTime              // Fecha del servicio
  mileage      Int?                  // Km en el momento del servicio
  workDone     String                // Trabajo realizado
  nextReviewDate DateTime?           // Fecha sugerida de próxima revisión
  nextMileage  Int?                  // Km sugerido para próxima revisión
  price        Float?                // Precio cobrado por el servicio
  // Metadatos
  stampedBy    String?               // Nombre del mecánico o responsable
  createdAt    DateTime @default(now())
}


model BlockedSlot {
  id        String   @id @default(cuid())
  garageId  String
  garage    Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)
  date      DateTime
  createdAt DateTime @default(now())

  @@unique([garageId, date])
}
