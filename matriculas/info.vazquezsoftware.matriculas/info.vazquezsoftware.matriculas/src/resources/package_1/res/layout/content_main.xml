<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:layout_width="fill_parent"
                android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="horizontal"
                android:id="@id/llBannerContainer"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true" />
  <RelativeLayout android:gravity="center_horizontal"
                  android:id="@id/rlBuscar"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="150.0dp">
    <EditText android:textSize="40.0sp"
              android:textStyle="bold"
              android:id="@id/etMatricula"
              android:background="@drawable/plate"
              android:paddingLeft="40.0dp"
              android:paddingBottom="5.0dp"
              android:layout_width="300.0dp"
              android:layout_height="70.0dp"
              android:maxLines="1"
              android:maxLength="10"
              android:inputType="textCapCharacters|textNoSuggestions" />
    <ImageButton android:id="@id/ibBorrar"
                 android:layout_width="50.0dp"
                 android:layout_height="70.0dp"
                 android:src="@drawable/ic_clear_black_24dp"
                 android:layout_toRightOf="@id/etMatricula"
                 android:layout_alignParentTop="true"
                 android:onClick="onClickBorrar" />
  </RelativeLayout>
  <Button android:background="@drawable/border_button"
          android:paddingRight="30.0dp"
          android:layout_width="fill_parent"
          android:layout_height="wrap_content"
          android:layout_marginLeft="15.0dp"
          android:layout_marginTop="20.0dp"
          android:layout_marginRight="15.0dp"
          android:text="@string/buscar"
          android:drawableRight="@0x7f0800ce"
          android:layout_below="@id/rlBuscar"
          android:onClick="onClickBuscar" />
</RelativeLayout>