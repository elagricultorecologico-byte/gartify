<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:theme="@android:style/Theme.NoTitleBar"
                android:padding="10.0dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="300.0dp" xmlns:android="http://schemas.android.com/apk/res/android">
  <TextView android:textSize="22.0sp"
            android:textStyle="bold"
            android:textColor="#000"
            android:gravity="center_horizontal"
            android:id="@id/tvTitle"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center" />
  <ScrollView android:id="@id/svInfo"
              android:fadingEdgeLength="20.0dp"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_below="@id/tvTitle"
              android:requiresFadingEdge="vertical">
    <LinearLayout android:layout_gravity="center"
                  android:orientation="horizontal"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
      <TextView android:textColor="#000"
                android:gravity="center"
                android:id="@id/tvInfo"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10.0dp"
                android:text="@string/policy_info"
                android:textAlignment="center" />
    </LinearLayout>
  </ScrollView>
  <Button android:textSize="20.0sp"
          android:textColor="#000"
          android:id="@id/btAceptar"
          android:background="@drawable/border_dialog"
          android:padding="10.0dp"
          android:layout_width="fill_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="10.0dp"
          android:text="@string/aceptar"
          android:layout_below="@id/svInfo" />
</RelativeLayout>