<?xml version='1.0' encoding='utf-8' ?>
<RelativeLayout android:background="#ffffff"
                android:fitsSystemWindows="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" xmlns:android="http://schemas.android.com/apk/res/android">
  <LinearLayout android:orientation="vertical"
                android:id="@id/llHeader"
                android:background="@drawable/border"
                android:padding="16.0dp"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16.0dp"
                android:elevation="2.0dp">
    <TextView android:textSize="18.0sp"
              android:textStyle="bold"
              android:textColor="#000000"
              android:id="@id/tvModel"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:textAlignment="center" />
    <TextView android:textSize="16.0sp"
              android:textColor="#555555"
              android:id="@id/tvSubInfo"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="8.0dp"
              android:textAlignment="center" />
  </LinearLayout>
  <Button android:id="@id/btnShare"
          android:background="@drawable/border_button"
          android:paddingRight="50.0dp"
          android:visibility="invisible"
          android:layout_width="fill_parent"
          android:layout_height="50.0dp"
          android:layout_margin="16.0dp"
          android:text="@string/compartir_informe"
          android:drawableRight="@drawable/ic_share"
          android:layout_alignParentBottom="true" />
  <ScrollView android:id="@id/svContent"
              android:background="@drawable/border"
              android:padding="16.0dp"
              android:layout_width="fill_parent"
              android:layout_height="fill_parent"
              android:layout_marginBottom="0.0dp"
              android:layout_above="@id/btnShare"
              android:layout_below="@id/llHeader"
              android:layout_marginStart="16.0dp"
              android:layout_marginEnd="16.0dp"
              android:elevation="2.0dp">
    <TextView android:textSize="16.0sp"
              android:textColor="#000000"
              android:id="@id/tvContent"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content" />
  </ScrollView>
  <LinearLayout android:gravity="center"
                android:orientation="vertical"
                android:id="@id/llLoading"
                android:background="#ddffffff"
                android:focusable="true"
                android:visibility="visible"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
    <ProgressBar android:layout_width="wrap_content"
                 android:layout_height="wrap_content" />
    <TextView android:textSize="16.0sp"
              android:textStyle="bold"
              android:textColor="#000000"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="16.0dp"
              android:text="@string/ia_analizando_progress"
              android:textAlignment="center" />
  </LinearLayout>
</RelativeLayout>